---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import KPICards from '../components/KPICards.astro';
import Timeline from '../components/Timeline.astro';
import Footer from '../components/Footer.astro';
---
<MainLayout>
  <Header />
  <main>
    <Hero
      roundName="Funding Round A"
      equityTarget="THB 1,500,000"
      committedAmount="THB 1,050,000"
      equityAvailable="30%"
      backgroundImage="/hero-solar-farm.jpg"
    />
    <KPICards />
    <Timeline />
  </main>
  <Footer />
</MainLayout>
