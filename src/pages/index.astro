---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import KPICards from '../components/KPICards.astro';
import Timeline from '../components/Timeline.astro';
import Memorandum from '../components/Memorandum.astro';
import Footer from '../components/Footer.astro';

const lang = 'en';
---
<MainLayout lang={lang}>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} backgroundImage="/hero-solar-farm.jpg" />
    <KPICards lang={lang} />
    <Timeline lang={lang} />
    <Memorandum lang={lang} />
  </main>
  <Footer lang={lang} />
</MainLayout>
