---
import { translations } from '../i18n/translations.js';

interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
const t = translations[lang] || translations.en;
const currentYear = new Date().getFullYear();
---
<footer class="bg-charcoal text-white/70 py-16">
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
      <div>
        <p class="font-extrabold text-lg text-white mb-3">Solar Khanom</p>
        <p class="text-sm leading-relaxed">
          {t.footer.tagline}
        </p>
      </div>
      <div>
        <p class="font-bold text-white text-sm uppercase tracking-widest mb-3">{t.footer.legalHeading}</p>
        <ul class="space-y-2 text-sm">
          <li><a href="#memorandum" class="hover:text-white transition-colors">{t.footer.memorandum}</a></li>
          <li><a href="/terms" class="hover:text-white transition-colors">{t.footer.terms}</a></li>
          <li><a href="/privacy" class="hover:text-white transition-colors">{t.footer.privacy}</a></li>
        </ul>
      </div>
      <div>
        <p class="font-bold text-white text-sm uppercase tracking-widest mb-3">{t.footer.contactHeading}</p>
        <p class="text-sm">investors@solarkhanom.example</p>
      </div>
    </div>
    <div class="pt-8 border-t border-white/10 text-xs text-white/40 leading-relaxed">
      <p>
        &copy; {currentYear} Thai Online Solutions Co., Ltd. (DBD Registration No. 08455670279).
        {t.footer.copyright}
      </p>
    </div>
  </div>
</footer>
