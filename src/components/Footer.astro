      <div>
        <p class="font-extrabold text-lg text-white mb-3">Solar Khanom</p>
        <p class="text-sm leading-relaxed">
          Utility-scale solar infrastructure investment in Nakhon Si Thammarat, Thailand.
        </p>
      </div>
      <div>
        <p class="font-bold text-white text-sm uppercase tracking-widest mb-3">Legal</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/memorandum.pdf" class="hover:text-white transition-colors">Investment Memorandum</a></li>
          <li><a href="/terms" class="hover:text-white transition-colors">Terms &amp; Risk Disclosure</a></li>
          <li><a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a></li>
        </ul>
