---
const navLinks = [
  { label: 'Metrics', href: '#metrics' },
  { label: 'Roadmap', href: '#timeline' },
  { label: 'Invest', href: '#invest' },
];
---
<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-black/5">
  <div class="container mx-auto px-6 max-w-7xl flex items-center justify-between h-20">
    <a href="/" class="font-extrabold text-xl tracking-tight text-charcoal">
      Solar <span class="text-primary">Khanom</span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a href={link.href} class="text-sm font-medium text-charcoal/70 hover:text-primary transition-colors">
          {link.label}
        </a>
      ))}
    </nav>
    <a
      href="/portal"
      class="px-5 py-2.5 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors"
    >
      Shareholder Login
    </a>
  </div>
</header>
