---
import { translations } from '../i18n/translations.js';

interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
const t = translations[lang] || translations.en;
const homeHref = lang === 'th' ? '/th/' : '/';
const otherLang = lang === 'th' ? 'en' : 'th';
const switchHref = lang === 'th' ? '/' : '/th/';

const navLinks = [
  { label: t.nav.metrics, href: `${homeHref}#metrics` },
  { label: t.nav.roadmap, href: `${homeHref}#timeline` },
];
---
<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-black/5">
  <div class="container mx-auto px-6 max-w-7xl flex items-center justify-between h-20">
    <a href={homeHref} class="font-extrabold text-xl tracking-tight text-charcoal">
      Solar <span class="text-primary">Khanom</span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a href={link.href} class="text-sm font-medium text-charcoal/70 hover:text-primary transition-colors">
          {link.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-4">
      <a
        href={switchHref}
        class="text-sm font-bold text-charcoal/60 hover:text-primary transition-colors uppercase"
        aria-label={`Switch to ${otherLang === 'th' ? 'Thai' : 'English'}`}
      >
        {otherLang.toUpperCase()}
      </a>
      <a
        href="/portal"
        class="px-5 py-2.5 bg-primary text-white text-sm font-bold rounded-lg hover:bg-primary/90 transition-colors"
      >
        {t.nav.login}
      </a>
    </div>
  </div>
</header>
