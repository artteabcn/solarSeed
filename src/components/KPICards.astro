---
/**
 * KPICards.astro
 * Institutional KPI cards for the Solar Khanom Investment Platform.
 * Designed for modularity and high-fidelity rendering in Astro.
 */
import { translations } from '../i18n/translations.js';

interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
const t = translations[lang] || translations.en;
const metrics = t.kpi.metrics;
---

<section class="py-24 bg-surface-container-low" id="metrics">
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="text-center mb-16">
      <h2 class="font-headline-md text-3xl md:text-4xl font-bold text-charcoal mb-4">
        {t.kpi.heading}
      </h2>
      <p class="text-charcoal/60 max-w-2xl mx-auto">
        {t.kpi.subheading}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {metrics.map((item) => (
        <div class="bg-white p-8 rounded-card border border-black/5 shadow-soft hover:shadow-lg transition-shadow duration-300 group">
          <div class="flex items-start justify-between mb-6">
            <div class="p-3 rounded-lg bg-primary/5 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
              {/* Lucide-inspired placeholder icons */}
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                width="24" 
                height="24" 
                viewBox="0 0 24 24" 
                fill="none" 
                stroke="currentColor" 
                stroke-width="2" 
                stroke-linecap="round" 
                stroke-linejoin="round" 
                class="w-6 h-6"
              >
                {item.icon === 'database' && <><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><path d="M7 2v20"/><path d="M17 2v20"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/></>}
                {item.icon === 'users' && <><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></>}
                {item.icon === 'zap' && <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>}
                {item.icon === 'sun' && <><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="M4.93 4.93l1.41 1.41"/><path d="M17.66 17.66l1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="M4.93 19.07l1.41-1.41"/><path d="M17.66 6.34l1.41-1.41"/></>}
                {item.icon === 'map' && <><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></>}
                {item.icon === 'calendar' && <><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></>}
                {item.icon === 'activity' && <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>}
                {item.icon === 'trending-up' && <><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></>}
                {item.icon === 'refresh-cw' && <><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/></>}
              </svg>
            </div>
          </div>
          
          <p class="text-xs font-bold uppercase tracking-widest text-charcoal/40 mb-2">
            {item.label}
          </p>
          <p class="text-2xl font-bold text-charcoal group-hover:text-primary transition-colors duration-300">
            {item.value}
          </p>
        </div>
      ))}
    </div>

    <div class="mt-16 p-8 bg-primary/5 rounded-card border border-primary/10 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center text-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
          <p class="font-bold text-charcoal">{t.kpi.calloutTitle}</p>
          <p class="text-sm text-charcoal/60">{t.kpi.calloutDesc}</p>
        </div>
      </div>
      <a href="/memorandum.pdf" class="text-primary font-bold hover:underline flex items-center gap-2">
        {t.kpi.calloutCta}
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .font-headline-md { font-family: 'Manrope', sans-serif; }
  .rounded-card { border-radius: 12px; }
  .shadow-soft { box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04); }
  .bg-surface-container-low { background-color: #f3f3f3; }
  .text-charcoal { color: #333333; }
  .text-primary { color: #1E8E5A; }
  .bg-primary { background-color: #1E8E5A; }
  .text-secondary { color: #D4AF37; }
</style>
